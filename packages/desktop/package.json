{
  "name": "@agent-hotline/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Tauri v2 desktop shell for Agent Hotline.",
  "type": "module",
  "scripts": {
    "dev": "node scripts/guarded-dev.mjs",
    "dev:ui": "node scripts/guarded-ui-dev.mjs",
    "build:ui": "node scripts/write-runtime-config.mjs && vite build",
    "install:tts": "node scripts/install-headtts-assets.mjs",
    "postinstall": "npm run install:tts",
    "test": "node --test test/*.test.js",
    "check": "npm run build:ui && cargo check --manifest-path src-tauri/Cargo.toml",
    "tauri": "node scripts/tauri-guard.mjs"
  },
  "dependencies": {
    "@met4citizen/headtts": "^1.3.0",
    "@soundtouchjs/audio-worklet": "^2.0.4",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-notification": "^2.0.0",
    "kokoro-js": "^1.2.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "vite": "^7.0.0"
  }
}
