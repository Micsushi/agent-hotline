{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Hotline",
  "version": "1.1.0",
  "identifier": "local.agent-hotline.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:ui",
    "beforeBuildCommand": "npm run build:ui",
    "devUrl": "http://127.0.0.1:4778",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Agent Hotline",
        "width": 380,
        "height": 520,
        "minWidth": 320,
        "minHeight": 420,
        "resizable": true,
        "decorations": false,
        "center": true,
        "focus": false,
        "visible": false,
        "theme": "Dark",
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --autoplay-policy=no-user-gesture-required"
      },
      {
        "label": "mini",
        "url": "mini.html",
        "title": "Agent Hotline",
        "width": 340,
        "height": 268,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
